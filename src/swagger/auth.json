{
    "swagger": "2.0",
    "info": {
        " description": "This is a Documentation of CRM NodeJS API project for Paie Cash Enterprise",
        "version": "1.0.0",
        "title": "CRM API",
        "contact": {
            "email": "paulinlenasaein@gmail.com"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        }
    },
    "tags": {
        "name": "Auth",
        "description": "API pour la gestion des authentifications"
    },
    "schemes": ["http"],
    "host": "localhost:5000",
    "basePath": "/",
    "paths": {
        "/users/login/{role}": {
            "get": {
                "tags": ["Auth"],
                "summary": "Connexion d'un utilisateur",
                "description": "Connecter un utilisateur à la plateforme",
                "produces": ["application/json"],
                "parameters": [{
                    "name": "basic-auth",
                    "in": "header",
                    "description": "username:password in basic auth",
                    "required": true,
                    "type": "string"
                }],
                "responses": {
                    "200": {
                        "description": "opération réussie",
                        "schema": {
                            "type": "object",
                            "$ref": "#/definitions/Connect"
                        }
                    },
                    "401": {
                        "description": "Opération non autorisé",
                        "schema": {
                            "$ref": "#/definitions/MessageResponse"
                        }
                    }
                }
            }
        },
        "/users/refresh/{logOrEmail}": {
            "get": {
                "tags": ["Auth"],
                "summary": "Rafraîchir le token",
                "description": "Mettre à jour le token de l'utilisateur",
                "produces": ["application/json"],
                "parameters": [{
                        "name": "token",
                        "in": "header",
                        "description": "Token de connexion de l'utilisateur",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "name": "logOrEmail",
                        "in": "path",
                        "description": "login ou email de l'utilisateur",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "operation réussie",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "401": {
                        "description": "Opération non autorisé",
                        "schema": {
                            "$ref": "#/definitions/MessageResponse"
                        }
                    }
                }
            }
        },
        "/users/uppass/{id}": {
            "get": {
                "tags": ["Auth"],
                "summary": "Modifier le mot de passe d'un utilisateur donné",
                "description": "Modifier le mot de passe d'un utilisateur donné",
                "produces": ["application/json"],
                "parameters": [{
                        "name": "token",
                        "in": "header",
                        "description": "Token de connexion de l'utilisateur",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID du utilisateur concerné",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "operation réussie",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/MessageResponse"
                            }
                        }
                    },
                    "401": {
                        "description": "Opération non autorisé",
                        "schema": {
                            "$ref": "#/definitions/MessageResponse"
                        }
                    }
                }
            }
        },
        "definitions": {
            "Connect": {
                "type": "object",
                "properties": {
                    "status": {
                        "type": "integer"
                    },
                    "data": {
                        "type": "object"
                    },
                    "userToken": {
                        "type": "string"
                    }
                }
            }
        },
        "MessageResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "integer"
                },
                "message": {
                    "type": "string"
                }
            }
        }
    }
}